{
    "project": {
        "name": "ex04",
        "version": "1.00"
    },
    "provider": {
        "name": "openai",
        "model": "deepseek/deepseek-v3.2",
        "api_key_env": "OPENAI_API_KEY",
        "base_url": "https://openrouter.ai/api/v1",
        "max_tokens": 100000
    },
    "graphify": {
        "graph_home": "./graph-home",
        "output_subdir": "graphify-out"
    },
    "vault": {
        "output_dir": "./obsidian"
    },
    "agent": {
        "max_iterations": 5,
        "max_suspects": 5,
        "context_window_tokens": 100000
    },
    "comparison": {
        "naive_file_limit": 20,
        "guided_context_limit": 100000
    },
    "paths": {
        "target_codebase": "./graph-home/.graphify/repos/andela/buggy-python",
        "reports_dir": "./reports",
        "artifacts_dir": "./artifacts"
    }
}
